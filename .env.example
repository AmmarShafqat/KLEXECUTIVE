# Google Maps — Maps JavaScript API + Places
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
# Optional: Cloud-styled Map ID. Leave blank to use default Google styling.
NEXT_PUBLIC_GOOGLE_MAPS_CLIENT_ID=
# Flip to "true" once the Directions API is enabled on your Google Cloud project.
# When false, the booking widget skips the Directions call and uses a coordinate-
# based distance estimate (haversine × 1.3 / 28 mph). Eliminates console errors
# when the API isn't enabled, at the cost of a less precise drive distance.
NEXT_PUBLIC_GOOGLE_DIRECTIONS_ENABLED=false

# Backend GraphQL endpoint (klexective-admin running locally on port 4000)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# Org slug that this landing site represents (must match `organizations.slug` in the backend DB)
NEXT_PUBLIC_ORG_SLUG=klexec-executive

# Stripe — PUBLISHABLE key only on the frontend (server-only secret key lives in the backend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
